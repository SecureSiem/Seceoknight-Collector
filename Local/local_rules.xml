<group name="yara,">
  <rule id="108000" level="0">
    <decoded_as>YARA_decoder</decoded_as>
    <description>YARA grouping rule</description>
  </rule>
  <rule id="108001" level="10">
    <if_sid>108000</if_sid>
    <match>wazuh-YARA: INFO - Scan result: </match>
    <description>File "$(YARA.scanned_file)" is a positive match for YARA rule: $(YARA.rule_name)</description>
  </rule>

  <rule id="108002" level="5">
    <if_sid>108000</if_sid>
    <field name="YARA.file_deleted">\.</field>
    <description>Active response successfully removed malicious file "$(YARA.file_deleted)"</description>
  </rule>

  <rule id="108003" level="12">
    <if_sid>108000</if_sid>
    <field name="YARA.file_not_deleted">\.</field>
    <description>Active response unable to delete malicious file "$(YARA.file_not_deleted)"</description>
  </rule>
</group>

<group name="seceoknight-enrich,">
  <rule id="209111" level="10">
    <decoded_as>SeceoKnight_enrich_decoder</decoded_as>
    <description>SeceoKnight enrichment for base rule $(enrich.base_rule_id) on agent $(enrich.agent) ip=$(enrich.ip) device=$(enrich.device): $(enrich.seceoknight_response)</description>
  </rule>
</group>

<group name="local,malware,">
 <rule id="100002" level="10">
  <if_sid>554</if_sid>

  <!-- must be in blacklist -->
  <list field="md5" lookup="match_key">etc/lists/malware-hashes</list>

  <!-- must NOT be in allowlist -->
  <list field="md5" lookup="not_match_key">etc/lists/md5-allowlist</list>

  <description>Blacklist MD5 matched (not allowlisted): $(file)</description>
</rule>

<rule id="100003" level="12">
 <if_sid>100002</if_sid>
 <field name="file" type="pcre2">(?i)^[c-z]:\\</field>
 <description>Potential malware detected: File $(file) matched known malicious hash</description>
</rule>
</group>


<group name="fim,dlp">

  <rule id="100501" level="12">
    <if_sid>550</if_sid>
    <match>salary|confidential|client_data|finance|secret|payroll</match>
    <description>Sensitive file MODIFIED: $(file)</description>
  </rule>

  <rule id="100500" level="12">
    <if_sid>554</if_sid>
    <match>salary|confidential|client_data|finance|secret|payroll</match>
    <description>Sensitive file ADDED: $(file)</description>
  </rule>

  <rule id="100502" level="12">
    <if_sid>553</if_sid>
    <match>salary|confidential|client_data|finance|secret|payroll</match>
    <description>Sensitive file DELETED: $(file)</description>
  </rule>

</group>
