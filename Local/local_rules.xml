<!-- Example -->
<group name="local,syslog,sshd,">

  <!--
  Dec 10 01:02:02 host sshd[1234]: Failed none for root from 1.1.1.1 port 1066 ssh2
  -->
  <rule id="100001" level="5">
    <if_sid>5716</if_sid>
    <srcip>1.1.1.1</srcip>
    <description>sshd: authentication failed from IP 1.1.1.1.</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>

</group>

<!-- Abnormal Destination IP Detection by AbuseIPDB list -->
<group name="fortigate, syslog, local, sshd">
 <rule id="101103" level="12">
   <options>alert_by_email</options>
   <if_group>fortigate</if_group>
   <list field="dstip" lookup="address_match_key">etc/lists/abuseipdb_blacklist</list>
   <description>FortiGate: Destination IP is in the AbuseIPDB blacklist. $(msg)</description>
   <group>fortigate,local,</group>
 </rule>
</group>


<!-- Abnormal Source IP Detection by AbuseIPDB list -->
<group name="fortigate, syslog, local, sshd, authentication_failed, invalid_login">
 <rule id="101104" level="12">
   <options>alert_by_email</options>
   <if_group>fortigate</if_group>
   <list field="srcip" lookup="address_match_key">etc/lists/abuseipdb_blacklist</list>
   <description>FortiGate: Source IP is in the AbuseIPDB blacklist. $(msg)</description>
   <group>fortigate,local,</group>
 </rule>

  <rule id="100950" level="15">
  <if_sid>101104</if_sid>
  <field name="data.action">accept</field>
  <description>CRITICAL: Blacklisted IP allowed through firewall</description>
</rule>
  
</group>


<group name="office365, office365, AzureActiveDirectoryStsLogon">
  <rule id="101106" level="12">
    <options>alert_by_email</options>
    <if_group>office365</if_group>
    <list field="office365.ClientIP" lookup="address_match_key">etc/lists/abuseipdb_blacklist</list>
    <description>Office365: Client IP matches AbuseIPDB blacklist. $(office365.UserId) operation $(office365.Operation)</description>
    <group>office365,AzureActiveDirectoryStsLogon,</group>
  </rule>
</group>

<!-- Abnormal Destination IP Detection by AbuseIPDB list -->
<group name="windows, sysmon, sysmon_event3, abuseipdb">
  <rule id="101107" level="12">
    <options>alert_by_email</options>
    <if_group>sysmon_event3</if_group>

    <list field="win.eventdata.destinationIp" lookup="address_match_key">etc/lists/abuseipdb_blacklist</list>

    <description>Sysmon E3: Destination IP $(win.eventdata.destinationIp):$(win.eventdata.destinationPort) is in AbuseIPDB blacklist. user=$(win.eventdata.user) image=$(win.eventdata.image)</description>
    <group>sysmon_event3,sysmon,</group>
  </rule>
</group>


<group name="fortigate,firewall,">
  <rule id="101105" level="12">
   <if_sid>5750</if_sid> <!-- FortiGate base traffic rule -->
   <match>policyid":"27"</match>
   <description>FortiGate: MaliciousFEED deny policy triggered.</description>
   <group>fortigate,firewall,maliciousfeed</group>
  </rule>

</group>

<group name="phishing, email,">
  <rule id="100100" level="10">
    <decoded_as>json</decoded_as>
    <field name="scan_result">urlscan.io</field>
    <description>Phishing URL detected via URLScan.io in email</description>
  </rule>
</group>

<group name="windows, sysmon, sysmon_event1, tor">
  <rule id="130001" level="12">
    <if_matched_sid>61603</if_matched_sid>
    <match>Tor Browser</match>
    <description>Tor Browser execution detected</description>
  </rule>
</group>

<group name="windows-usb-detect,">
  <rule id="111000" level="12">
    <if_sid>60227</if_sid>
    <field name="win.system.eventID">^6416$</field>
    <match>USBSTOR\\Disk</match>
    <options>no_full_log</options>
    <description>Windows: A PNP device $(win.eventdata.deviceDescription) was connected to $(win.system.computer)</description>
  </rule>
</group>

